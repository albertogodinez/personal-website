---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const workExperience = (await getCollection('experience'))
  .filter((exp) => exp.data.type === 'work')
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());

const formatDate = (start: Date, end: Date | null) => {
  const startYear = start.getFullYear();
  if (!end) return `${startYear}—present`;
  const endYear = end.getFullYear();
  return startYear === endYear ? `${startYear}` : `${startYear}—${endYear}`;
};
---

<BaseLayout title="alberto godinez" hideFooter>
  <div class="landing">
    <img src="/globe.svg" alt="" class="landing__icon landing__icon--left" />
    <img src="/doorway.svg" alt="" class="landing__icon landing__icon--right" />
    <div class="landing__container">
      <div class="landing__left">
        <div class="fade-in d1">
          <h1 class="landing__label">alberto godinez</h1>
          <p class="landing__role">software developer — austin, tx</p>
        </div>
        <div class="fade-in d2">
          <p class="landing__bio">
            currently working on adding trip planning features on all of expedia group's platforms. hope you enjoy this
            little sliver of the internet.
          </p>
        </div>
      </div>

      <div class="landing__right">
        <div class="fade-in d3">
          <p class="landing__exp-label">experience</p>
          <ul class="landing__exp-list">
            {
              workExperience.map((exp) => (
                <li class="landing__exp-item">
                  <div class="landing__exp-header">
                    <span class="landing__exp-name">{exp.data.company.toLowerCase()}</span>
                    <span class="landing__exp-date">{formatDate(exp.data.startDate, exp.data.endDate)}</span>
                  </div>
                  <div class="landing__exp-body">
                    {exp.data.description && <p class="landing__exp-desc">{exp.data.description.toLowerCase()}</p>}
                    {exp.data.tags && exp.data.tags.length > 0 && (
                      <div class="landing__exp-tags">
                        {exp.data.tags.map((tag: string) => (
                          <span class="landing__exp-tag">{tag.toLowerCase()}</span>
                        ))}
                      </div>
                    )}
                    <div class="landing__exp-body-spacer" />
                  </div>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <footer class="landing__footer fade-in d4">
      <a href="mailto:albertogodinez@outlook.com" class="shimmer-link">email</a>
      <a href="https://linkedin.com/in/albertogodinez" class="shimmer-link" rel="noopener">linkedin</a>
      <a href="https://github.com/albertogodinez" class="shimmer-link" rel="noopener">github</a>
    </footer>
  </div>
</BaseLayout>

<style>
  @import '../styles/landing.css';
</style>

<script>
  // Accordion — measure content height and toggle
  document.querySelectorAll('.landing__exp-item').forEach((item) => {
    const body = item.querySelector('.landing__exp-body') as HTMLElement;
    if (!body) return;
    body.style.height = 'auto';
    const h = body.scrollHeight;
    (item as HTMLElement).style.setProperty('--body-height', h + 'px');
    body.style.height = '0';
  });

  document.querySelectorAll('.landing__exp-header').forEach((header) => {
    header.addEventListener('click', () => {
      const item = header.closest('.landing__exp-item');
      if (item) item.classList.toggle('open');
    });
  });
</script>
