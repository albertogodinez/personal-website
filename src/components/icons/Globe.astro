---
const { class: className, ...rest } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <defs>
    <clipPath id="globe-clip">
      <path d="M0 0h24v24H0z M20.0 9a4.5 4.5 0 1 0-9 0 4.5 4.5 0 0 0 9 0z" clip-rule="evenodd" />
    </clipPath>
  </defs>
  <g clip-path="url(#globe-clip)">
    <circle cx="12" cy="12" r="9" />
    <path d="M12 3c-2.5 0-4.5 4-4.5 9s2 9 4.5 9" />
    <path d="M12 3c2.5 0 4.5 4 4.5 9s-2 9-4.5 9" />
    <line x1="3.5" y1="12" x2="20.5" y2="12" />
    <line x1="5.5" y1="7.5" x2="18.5" y2="7.5" />
    <line x1="5.5" y1="16.5" x2="18.5" y2="16.5" />
  </g>
  <circle cx="15.5" cy="9" r="2.5" fill="currentColor" stroke="none" />
</svg>
